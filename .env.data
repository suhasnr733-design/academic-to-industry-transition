# .env.data

# Database URLs
DATABASE_URL=sqlite:///data/processed/industry_data.db
# DATABASE_URL=postgresql://user:password@localhost:5432/industry_db

# API Keys (Obtain these from respective platforms)
COURSERA_API_KEY=your_coursera_api_key_here
UDEMY_API_KEY=your_udemy_api_key_here
UDEMY_API_SECRET=your_udemy_api_secret_here

# Scraping Settings
SCRAPING_DELAY=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Logging
LOG_LEVEL=INFO